<header class="fixed top-0 w-full z-50 bg-cyberwhite/50 backdrop-blur-3xl border-b border-black/5 py-6 px-6 md:px-12">
    <div class="max-w-[1920px] mx-auto flex justify-between items-center">
        <div class="flex gap-8 text-[9px] font-light uppercase tracking-[0.3em] text-black/60">
            <a href="/" class="hover:text-black transition-colors">[ ACCUEIL ]</a>
            <a href="/collections/all" class="hover:text-black transition-colors">[ REPERTOIRE_TEXTILE ]</a>
        </div>
        
        <a href="/" class="text-center block">
            <h1 class="font-serif text-2xl md:text-4xl font-light tracking-[0.1em] text-black leading-none">{{ shop.name }}</h1>
            <p class="text-[7px] tracking-[0.7em] uppercase text-gold mt-2 pl-2">DECRYPTED INTERACTIVE REPERTOIRE // {{ 'now' | date: '%Y' }}</p>
        </a>

        <div class="flex items-center gap-8 text-[9px] font-light uppercase tracking-[0.3em] text-black/60">
            <a href="/cart" class="border border-black/10 bg-white/90 text-black px-6 py-2.5 flex items-center gap-3 hover:border-black transition-all font-medium">
                COFFRE CENTRAL : <span class="text-gold" id="cart-counter-global">{{ cart.item_count }}</span>
            </a>
        </div>
    </div>
</header>