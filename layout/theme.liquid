<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght=0,300;0,400;1,300&family=Montserrat:wght@100;200;300;400;700;900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <!-- Styles Shopify -->
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
</head>
<body class="msp-body-wrapper" id="msp-global-container">
    
    <div class="film-grain"></div>
    <div id="custom-cursor"></div>
    <div id="custom-cursor-aura"></div>
    
    <!-- Preloader -->
    {% include 'preloader' %}
    
    <!-- Header -->
    {% include 'header' %}
    
    <!-- Main Content -->
    <main class="pt-32">
        {{ content_for_layout }}
    </main>
    
    <!-- Footer -->
    {% include 'footer' %}
    
    <!-- Scripts -->
    {{ 'theme.js' | asset_url | script_tag }}
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['"Cormorant Garamond"', 'serif'],
                        sans: ['Montserrat', 'sans-serif'],
                    },
                    colors: {
                        gold: '#B89742',
                        goldlight: '#E5D5A6',
                        cyberwhite: '#FDFDFD',
                        luxeblack: '#0D0D0D',
                    }
                }
            }
        }
    </script>
</body>
</html>